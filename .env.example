# RedWeaver - environment template
# Copy to .env and set values. Do not commit .env.

# --- Django ---
# DJANGO_ENV=dev                 # dev | prod | test (settings overlay)
# DJANGO_DEBUG=1
# DJANGO_SECRET_KEY=change-me     # required in prod
# ALLOWED_HOSTS=localhost,127.0.0.1,web
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8001

# --- PostgreSQL (system of record) ---
POSTGRES_DB=redweaver
POSTGRES_USER=redweaver
POSTGRES_PASSWORD=redweaver
# DATABASE_URL is composed by docker-compose to postgres://...@postgres:5432/...

# --- Default admin (seeded by the one-shot migrate service) ---
# DJANGO_SUPERUSER_EMAIL=admin@redweaver.local
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=admin

# Auth: SimpleJWT signs with JWT_SECRET (falls back to DJANGO_SECRET_KEY).
# JWT_SECRET=

# LLM providers: set at least one. Can also be set via the Settings UI.
# Env vars take precedence over UI settings.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model provider preference: "openai" or "anthropic" (default: auto-detect from available keys)
# MODEL_PROVIDER=

# Model per provider (defaults shown). The default OpenAI model is gpt-4o-mini —
# cheap, but weaker reasoning yields shallower/less-accurate findings. For
# higher-quality assessments, upgrade the model (costs more per run):
#   MODEL_OPENAI=gpt-4o
# MODEL_OPENAI=gpt-4o-mini
# MODEL_ANTHROPIC=claude-sonnet-4-6-20260218
# MODEL_GOOGLE=gemini-3-flash

# NVD/CVE enrichment: an API key raises the rate limit (5→50 req/30s) so CVE
# lookups are far less likely to be throttled. Get one free at https://nvd.nist.gov/developers
# NVD_API_KEY=

# Ollama: local LLM inference (default: http://host.docker.internal:11434 in Docker)
# OLLAMA_BASE_URL=http://localhost:11434

# Redis (host port 6380). Roles split by DB: /0 pubsub, /1 Channels layer,
# /2 Celery broker. Composed internally by docker-compose.
# REDIS_URL=redis://localhost:6380/0
# CHANNEL_LAYERS_URL=redis://localhost:6380/1
# CELERY_BROKER_URL=redis://localhost:6380/2

# Screenshots (Playwright) — written under MEDIA_ROOT on a shared volume.
# SCREENSHOTS_DIR=/app/media/screenshots
# SCREENSHOT_TIMEOUT_SEC=30

# --- Knowledge base (pgvector RAG source) ---
# RedWeaver ships with a built-in security-methodology knowledge base under
# ./knowledge-base (mounted to /app/knowledge-base and auto-ingested on first
# startup via `manage.py ingest_kb`). This is the DEFAULT and works out of the
# box — no configuration needed.
#
# To use your OWN knowledge base instead, either:
#   (a) replace ./knowledge-base with a clone of a different repo of markdown
#       docs:  git clone <your-kb-repo> knowledge-base   (then re-ingest), or
#   (b) point KB_SOURCE_DIR at any directory of markdown (*.md) files.
# After changing the source, re-ingest with:
#   docker compose run --rm migrate python manage.py ingest_kb
# KB_SOURCE_DIR=/app/knowledge-base

# KB embeddings (pgvector RAG). These env vars only seed the INITIAL config —
# provider/model/device are also editable at runtime from the Settings UI
# (Knowledge Base Embeddings), which has a "Re-index" button that retypes the
# vector column and re-embeds automatically (no env edits or manual commands).
# Default uses OpenAI; switch to a local, offline HuggingFace model (no API key)
# via the LangChain SDK. The vector dimension is auto-detected from the model.
#   KB_EMBED_PROVIDER: openai | huggingface  (default: openai)
#   KB_EMBED_MODEL:    blank = provider default
#                      (openai: text-embedding-3-small;
#                       huggingface: sentence-transformers/all-MiniLM-L6-v2)
#   KB_EMBED_DIM:      must match the model output dim
#                      (openai 1536; all-MiniLM-L6-v2 384; bge-base 768; bge-large 1024)
#   KB_EMBED_DEVICE:   cpu | cuda  (HuggingFace only)
# KB_EMBED_PROVIDER=huggingface
# KB_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# KB_EMBED_DIM=384
# KB_EMBED_DEVICE=cpu
# Fully offline (after the model is cached/baked into the image):
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Frontend (build-time for Docker)
# VITE_BACKEND_URL=http://localhost:8000

# CrewAI: defaults reduce log noise and latency (set true to enable)
# CREW_VERBOSE=false
# CREW_MEMORY=false
# CREW_PLANNING=false

# Hunt SSE / Redis tuning
# INCLUDE_THINKING_STREAM=true
# THINKING_EMIT_INTERVAL_SEC=0.35
# RUN_STATE_FLUSH_INTERVAL_SEC=0.5
# Max reasoning steps stored in Redis for page reload (oldest dropped when over cap)
# RUN_REASONING_STEPS_MAX=800
# CREW_EXECUTOR_WORKERS=4
