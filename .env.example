# RedWeaver - environment template
# Copy to .env and set values. Do not commit .env.

# --- Django ---
# DJANGO_ENV=dev                 # dev | prod | test (settings overlay)
# DJANGO_DEBUG=1
# DJANGO_SECRET_KEY=change-me     # required in prod
# ALLOWED_HOSTS=localhost,127.0.0.1,web
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8001

# --- PostgreSQL (system of record) ---
POSTGRES_DB=redweaver
POSTGRES_USER=redweaver
POSTGRES_PASSWORD=redweaver
# DATABASE_URL is composed by docker-compose to postgres://...@postgres:5432/...

# --- Default admin (seeded by the one-shot migrate service) ---
# DJANGO_SUPERUSER_EMAIL=admin@redweaver.local
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=admin

# Auth: SimpleJWT signs with JWT_SECRET (falls back to DJANGO_SECRET_KEY).
# JWT_SECRET=

# LLM providers: set at least one. Can also be set via the Settings UI.
# Env vars take precedence over UI settings.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model provider preference: "openai" or "anthropic" (default: auto-detect from available keys)
# MODEL_PROVIDER=

# Ollama: local LLM inference (default: http://host.docker.internal:11434 in Docker)
# OLLAMA_BASE_URL=http://localhost:11434

# Redis (host port 6380). Roles split by DB: /0 pubsub, /1 Channels layer,
# /2 Celery broker. Composed internally by docker-compose.
# REDIS_URL=redis://localhost:6380/0
# CHANNEL_LAYERS_URL=redis://localhost:6380/1
# CELERY_BROKER_URL=redis://localhost:6380/2

# Screenshots (Playwright) — written under MEDIA_ROOT on a shared volume.
# SCREENSHOTS_DIR=/app/media/screenshots
# SCREENSHOT_TIMEOUT_SEC=30

# Knowledge service: path to your security methodology docs (mounted into knowledge container)
# Point this to a directory of markdown files. Without it, knowledge queries return empty results.
# KNOWLEDGE_DATA_PATH=/path/to/your/knowledge-docs

# Frontend (build-time for Docker)
# VITE_BACKEND_URL=http://localhost:8000

# CrewAI: defaults reduce log noise and latency (set true to enable)
# CREW_VERBOSE=false
# CREW_MEMORY=false
# CREW_PLANNING=false

# Hunt SSE / Redis tuning
# INCLUDE_THINKING_STREAM=true
# THINKING_EMIT_INTERVAL_SEC=0.35
# RUN_STATE_FLUSH_INTERVAL_SEC=0.5
# Max reasoning steps stored in Redis for page reload (oldest dropped when over cap)
# RUN_REASONING_STEPS_MAX=800
# CREW_EXECUTOR_WORKERS=4
